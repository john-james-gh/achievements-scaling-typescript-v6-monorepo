{
  "name": "@achievements-scaling-typescript-v6-monorepo/root",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "build:clean": "tsc -b --clean",
    "format": "prettier . --write && sort-package-json package.json apps/*/package.json libs/*/package.json",
    "format:check": "prettier . --check && sort-package-json package.json apps/*/package.json libs/*/package.json --check"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "sort-package-json": "^4.0.0",
    "typescript": "^6.0.3"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "24",
      "onFail": "warn"
    }
  }
}
